{
  "SessionStart": [
    {
      "type": "command",
      "command": "mkdir -p ~/.dippy && [ ! -f ~/.dippy/config ] && cp ${CLAUDE_PLUGIN_ROOT}/config/default.dippy ~/.dippy/config || true"
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "python ${CLAUDE_PLUGIN_ROOT}/bin/dippy-hook"
        }
      ]
    }
  ]
}
