{
  "name": "za-qe-tools",
  "version": "3.2.0",
  "description": "QE 通用工具集：Powerline 状态栏、系统通知、Bash 命令审批（Dippy）、会话事件流查看（ESP）",
  "author": {
    "name": "Alfie"
  },
  "keywords": ["statusbar", "notification", "monitor", "hook", "bash", "permissions", "session", "event-stream"],
  "commands": "./commands",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/auto-setup.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hook-router.py --event PreToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hook-router.py --event Stop",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hook-router.py --event PermissionRequest",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hook-router.py --event PostToolUse",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/scripts/hook-router.py --event PostToolUseFailure",
            "async": true
          }
        ]
      }
    ]
  }
}
